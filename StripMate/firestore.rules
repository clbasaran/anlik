rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the user has admin custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // NOTE: App Check enforcement is configured at the API level in Firebase Console
    // (Firestore → Settings → App Check). Rules-level enforcement is redundant with
    // the API-level flag, so no helper is defined here.

    // Helper: Check if the user account is NOT disabled or banned
    function isActiveUser() {
      return request.auth != null
        && (
          !exists(/databases/$(database)/documents/users/$(request.auth.uid))
          || (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('disabled', false) == false
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isSuspended', false) == false
          )
        );
    }

    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId
                    && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 60)
                    && (!('statusEmoji' in request.resource.data) || request.resource.data.statusEmoji.size() <= 4);
      allow update: if (request.auth != null && request.auth.uid == userId && isActiveUser()
                    && (!('bio' in request.resource.data) || request.resource.data.bio.size() <= 60)
                    && (!('statusEmoji' in request.resource.data) || request.resource.data.statusEmoji.size() <= 4)
                    && (
                      !('consent' in resource.data)
                      || request.resource.data.consent == resource.data.consent
                    )) || isAdmin();
      allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();

      match /private/{docId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }

      match /friendships/{friendId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
        allow create: if request.auth != null && isActiveUser()
                      && (request.auth.uid == userId || request.auth.uid == friendId)
                      && request.resource.data.timestamp == request.time;
        allow update: if request.auth != null && isActiveUser()
                      && (request.auth.uid == userId || request.auth.uid == friendId);
        allow delete: if (request.auth != null && (request.auth.uid == userId || request.auth.uid == friendId)) || isAdmin();
      }

      match /blocked/{blockedId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }

      // Send-groups: user-defined recipient lists for the send sheet.
      // Owned exclusively by the user — no other party can read/write.
      match /send_groups/{groupId} {
        allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }

      // Notifications subcollection
      match /notifications/{notifId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if (request.auth != null && request.auth.uid == userId) || isAdmin();
        allow update, delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      }
    }

    // Reports Collection
    match /reports/{reportId} {
      allow create: if request.auth != null && isActiveUser()
                    && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    // Strips Collection
    match /strips/{stripId} {
      function isStripParticipant() {
        return request.auth.uid == resource.data.senderId
               || request.auth.uid in resource.data.receiverIds;
      }

      // Banned/suspended/disabled users keep their auth session until iOS detects
      // the AppGuard status and signs them out, but rules must defend in depth:
      // gate reads on isActiveUser so a banned account cannot continue browsing
      // content while the client tears down.
      allow read: if (request.auth != null && isActiveUser() && isStripParticipant())
                  || isAdmin();
      allow create: if request.auth != null && isActiveUser()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.timestamp == request.time
                    && request.resource.data.receiverIds.size() >= 2
                    && request.resource.data.receiverIds.size() <= 51;
                    // NOTE: Self-echo guard (sender ∈ receiverIds) removed to keep
                    // backward compatibility with older App Store builds that may
                    // not include themselves in receiverIds. The iOS client already
                    // appends self in PhotoService.sendPhoto(), but we don't enforce
                    // it server-side to avoid breaking production users mid-update.
      // Update: sender can only modify allowed fields; receiver can only remove self
      allow update: if request.auth != null && isActiveUser() && (
        (
          resource.data.senderId == request.auth.uid
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.imageUrl == resource.data.imageUrl
          && request.resource.data.timestamp == resource.data.timestamp
        )
        || (
          request.auth.uid in resource.data.receiverIds
          && !(request.auth.uid in request.resource.data.receiverIds)
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.imageUrl == resource.data.imageUrl
          && request.resource.data.timestamp == resource.data.timestamp
        )
      ) || isAdmin();
      allow delete: if (request.auth != null && resource.data.senderId == request.auth.uid) || isAdmin();

      match /chats/{receiverId} {
        function isChatParticipant() {
          let strip = get(/databases/$(database)/documents/strips/$(stripId)).data;
          return (request.auth.uid == strip.senderId && receiverId in strip.receiverIds)
                 || request.auth.uid == receiverId;
        }

        allow read: if (request.auth != null && isActiveUser() && isChatParticipant()) || isAdmin();
        allow write: if false;

        match /messages/{messageId} {
          allow read: if (request.auth != null && isActiveUser() && isChatParticipant()) || isAdmin();
          allow create: if request.auth != null && isActiveUser()
                        && isChatParticipant()
                        && request.resource.data.senderId == request.auth.uid
                        && request.resource.data.text.size() <= 2000;
          allow update: if (request.auth != null && isChatParticipant()) || isAdmin();
          allow delete: if (request.auth != null && resource.data.senderId == request.auth.uid) || isAdmin();
        }
      }
    }

    // Notifications Collection
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if (request.auth != null && isActiveUser()
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.timestamp == request.time) || isAdmin();
      allow update: if (request.auth != null && request.auth.uid == resource.data.userId) || isAdmin();
      allow delete: if (request.auth != null && request.auth.uid == resource.data.userId) || isAdmin();
    }

    // Direct Messages Collection
    function isDMParticipant(threadId) {
      let parts = threadId.split('_');
      return parts.size() == 2
        && parts[0].size() > 0
        && parts[1].size() > 0
        && request.auth.uid in parts;
    }

    match /direct_messages/{threadId} {
      // Thread doc: only participants can read; writes restricted to meta fields
      allow read: if (request.auth != null && isActiveUser() && isDMParticipant(threadId)) || isAdmin();
      allow write: if (request.auth != null && isActiveUser() && isDMParticipant(threadId)) || isAdmin();

      match /messages/{messageId} {
        allow read: if (request.auth != null && isActiveUser() && isDMParticipant(threadId)) || isAdmin();
        allow create: if (request.auth != null && isActiveUser()
                      && request.resource.data.senderId == request.auth.uid
                      && isDMParticipant(threadId)
                      && request.resource.data.text.size() <= 2000) || isAdmin();
        // Update: only sender can modify own message (soft-delete), receiver can mark read
        allow update: if (request.auth != null && isActiveUser()
                      && isDMParticipant(threadId)
                      && (resource.data.senderId == request.auth.uid
                          || resource.data.receiverId == request.auth.uid)) || isAdmin();
        allow delete: if (request.auth != null && resource.data.senderId == request.auth.uid) || isAdmin();
      }
    }

    // Streaks Collection — server-managed, clients can only read
    match /streaks/{streakId} {
      allow read: if (request.auth != null && request.auth.uid in resource.data.userIds) || isAdmin();
      allow create: if false;
      // Participants may update ONLY freeze fields, exactly once per week
      // (transition from false → true). frozenUntil must land within the
      // next 49 hours so a malicious client can't lock a streak forever.
      // `get('freezeUsedThisWeek', false)` defaults missing fields to false,
      // which is necessary for streak docs created before the freeze feature
      // shipped (otherwise the equality check fails on undefined).
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.userIds
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['freezeUsedThisWeek', 'frozenUntil'])
                    && request.resource.data.freezeUsedThisWeek == true
                    && resource.data.get('freezeUsedThisWeek', false) == false
                    && request.resource.data.frozenUntil is timestamp
                    && request.resource.data.frozenUntil > request.time
                    && request.resource.data.frozenUntil <= request.time + duration.value(49, 'h');
      allow delete: if isAdmin();
    }

    // Daily Prompts Collection
    match /daily_prompts/{dateId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();

      match /completions/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && isActiveUser()
                      && request.auth.uid == userId
                      && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Usernames Collection
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Collection group query support — allows admin to query all messages across chats
    match /{path=**}/messages/{messageId} {
      allow read: if isAdmin();
    }

    // ===== Admin Panel Collections =====

    match /app_config/{docId} {
      // Authenticated users must be able to read this so the maintenance
      // flag and any other public app config (kill switches, daily prompt
      // overrides) reach them. Without this every signed-in user falls into
      // the AppGuard fail-closed branch and sees the maintenance screen.
      // Writes stay admin-only.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /notification_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /broadcast_notifications/{notifId} {
      allow read, write: if isAdmin();
    }

    match /admin_notification_templates/{templateId} {
      allow read, write: if isAdmin();
    }

    match /scheduled_notifications/{notifId} {
      allow read, write: if isAdmin();
    }

    match /admin_audit_log/{logId} {
      allow read, write: if isAdmin();
    }

    match /admin_word_filters/{filterId} {
      // Clients need to read the banned-word list to filter outgoing messages
      // before sending. Without read access every send hits the fail-open
      // branch in AppGuard and the filter becomes a no-op for all users.
      // Writes stay admin-only.
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /admin_roles/{roleId} {
      allow read, write: if isAdmin();
    }

    match /automation_rules/{ruleId} {
      allow read, write: if isAdmin();
    }

    match /automation_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Nudges subcollection — sender must be authenticated and provide their uid
    match /users/{userId}/nudges/{nudgeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isActiveUser()
                    && request.resource.data.senderId == request.auth.uid;
      allow delete: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // Support Chats — user can read/write own thread, admin can read/write all
    match /support_chats/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();

      match /messages/{messageId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
        // Users can only create messages with isAdmin=false; admins can set isAdmin=true
        allow create: if (request.auth != null && request.auth.uid == userId && request.resource.data.get('isAdmin', false) == false)
                      || isAdmin();
        allow update, delete: if isAdmin();
      }
    }
  }
}
