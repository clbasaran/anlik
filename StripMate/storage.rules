rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Strip photos — fileName must start with sender's uid (e.g. uid_timestamp.jpg)
    match /strips/{imageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                   && imageId.matches(request.auth.uid + '_.*')
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if request.auth != null
                   && imageId.matches(request.auth.uid + '_.*');
    }

    // Thumbnails generated by Cloud Function (read-only for clients)
    match /strips/thumbs/{thumbId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Voice messages — fileName must start with sender's uid
    match /voices/{voiceId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                   && voiceId.matches(request.auth.uid + '_.*')
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
      allow update: if false;
      allow delete: if request.auth != null
                   && voiceId.matches(request.auth.uid + '_.*');
    }

    // Avatars — only owner can write (fileName must start with uid)
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                   && fileName.matches(request.auth.uid + '.*')
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                   && fileName.matches(request.auth.uid + '.*');
    }

    // Chat photo replies — fileName must start with sender's uid
    match /chat_photos/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                   && fileName.matches(request.auth.uid + '_.*')
                   && request.resource.size < 3 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if request.auth != null
                   && fileName.matches(request.auth.uid + '_.*');
    }

    // DM photos — fileName must start with sender's uid
    match /dm_photos/{fileName} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                   && fileName.matches(request.auth.uid + '_.*')
                   && request.resource.size < 3 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow update: if false;
      allow delete: if request.auth != null
                   && fileName.matches(request.auth.uid + '_.*');
    }
  }
}
