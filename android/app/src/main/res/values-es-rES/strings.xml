    <string name="support_section_faq">PREGUNTAS FRECUENTES</string>
    <string name="support_faq_add_friend_q">como anado a alguien?</string>
    <string name="support_faq_add_friend_a">ve a anadir amistad y escribe el codigo de invitacion de 8 caracteres. tambien puedes escanear su qr.</string>
    <string name="support_faq_retention_q">cuanto tiempo se guardan mis fotos?</string>
    <string name="support_faq_retention_a">las fotos se guardan durante 30 dias y luego se eliminan automaticamente.</string>
    <string name="support_faq_streak_q">como funciona la racha?</string>
    <string name="support_faq_streak_a">si cada dia llega un momento de ida y vuelta, la racha sigue viva. si pasan dos dias vacios, se reinicia.</string>
    <string name="support_faq_widget_q">como anado el widget?</string>
    <string name="support_faq_widget_a">mantén pulsada la pantalla de inicio, toca el mas, busca anlik. y elige el tamano que quieras.</string>
    <string name="support_faq_delete_q">como elimino mi cuenta?</string>
    <string name="support_faq_delete_a">puedes borrarla desde ajustes, en gestion de cuenta. es una accion permanente.</string>
    <string name="support_faq_limit_q">cuantas amistades puedo tener como maximo?</string>
    <string name="support_faq_limit_a">puedes tener hasta 50 amistades. anlik. quiere seguir siendo un espacio pequeno y cercano.</string>
